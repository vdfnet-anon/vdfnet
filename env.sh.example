# env.sh.example — copy to env.sh and edit paths to your machine, then `source env.sh`
#
#   cp env.sh.example env.sh
#   # edit the paths below
#   source env.sh
#
# All training/eval scripts read these variables and fall back to ./data/* and
# ./checkpoints if they are unset, so the repo runs out of the box once your
# datasets are placed under ./data.

# SceneFlow training set root (contains FlyingThings3D/ Monkaa/ Driving/,
# each with frames_finalpass/ and disparity/).
export VDFNET_DATA="$PWD/data/SceneFlow"

# Zero-shot eval data root (contains ETH3D/ KITTI/ Middlebury/).
export VDFNET_EVAL_DATA="$PWD/data/eval_data"

# Where checkpoints are written / read.
export VDFNET_CKPT="$PWD/checkpoints"

# This repo's root (used by helper scripts to resolve `nets` imports).
export VDFNET_ROOT="$PWD"

# Directory holding the cloned official backbones for the multi-backbone
# ablation (GwcNet_base, GwcNet_render, PSMNet_base, PSMNet_render,
# aanet_base, aanet_render). See README "Multi-backbone reproduction".
export WORKSPACE="$PWD/backbones"
